<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Speedometer outer glow arc representing speed tuning -->
    <path
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:pathData="M 32 74 A 25 25 0 1 1 76 74">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:endX="76"
                android:endY="74"
                android:startX="32"
                android:startY="32"
                android:type="linear">
                <item
                    android:color="#FF0055"
                    android:offset="0.0" />
                <item
                    android:color="#00E5FF"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Speed ticks on the speedometer arc -->
    <path
        android:fillColor="#00E5FF"
        android:pathData="M30,48 L34,48 M74,48 L78,48 M54,26 L54,30 M38,36 L41,39 M67,39 L70,36"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeColor="#00E5FF" />

    <!-- Lightning Bolt (Tuning Power Badge) in the background of the scooter -->
    <path
        android:pathData="M 52,28 L 44,48 L 50,48 L 46,64 L 58,44 L 52,44 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="58"
                android:endY="64"
                android:startX="44"
                android:startY="28"
                android:type="linear">
                <item
                    android:color="#FFFF007F"
                    android:offset="0.0" />
                <item
                    android:color="#FFFFE100"
                    android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Stylized modern kick scooter -->
    
