        android:pathData="M 38 68 A 7 7 0 1 1 37.99 68 Z" />
    <!-- Rear Wheel Center (Dark Inner Rim) -->
    <path
        android:fillColor="#0F111A"
        android:pathData="M 38 68 A 4 4 0 1 1 37.99 68 Z" />
    <!-- Rear Wheel Hub (White Hubcap) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 38 68 A 1.5 1.5 0 1 1 37.99 68 Z" />

    <!-- Front Wheel Outer (Neon Blue Glow) -->
    <path
        android:fillColor="#00E5FF"
        android:pathData="M 70 68 A 7 7 0 1 1 69.99 68 Z" />
    <!-- Front Wheel Center (Dark Inner Rim) -->
    <path
        android:fillColor="#0F111A"
        android:pathData="M 70 68 A 4 4 0 1 1 69.99 68 Z" />
    <!-- Front Wheel Hub (White Hubcap) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 70 68 A 1.5 1.5 0 1 1 69.99 68 Z" />

